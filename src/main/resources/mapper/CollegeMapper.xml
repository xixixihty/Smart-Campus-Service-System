<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.hxq.smart_campus.mapper.CollegeMapper">

    <!-- 获取学院列表 -->
    <select id="getCollegeList" resultType="com.hxq.smart_campus.entity.vo.CollegeListVO">
        SELECT id, college_code, college_name, status, create_time
        FROM college
        <where>
            <if test="status != null and status != ''">
                AND status = #{status}
            </if>
            <if test="collegeName != null and collegeName != ''">
                AND college_name LIKE CONCAT('%', #{collegeName}, '%')
            </if>
        </where>
        ORDER BY create_time DESC
    </select>

    <!-- 新增学院 -->
    <insert id="insert" parameterType="com.hxq.smart_campus.entity.dto.CollegeCreateDTO">
        INSERT INTO college
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="collegeCode != null and collegeCode != ''">college_code,</if>
            <if test="collegeName != null and collegeName != ''">college_name,</if>
            <if test="dean != null and dean != ''">dean,</if>
            <if test="contactPhone != null and contactPhone != ''">contact_phone,</if>
            status,
        </trim>
        VALUES
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="collegeCode != null and collegeCode != ''">#{collegeCode},</if>
            <if test="collegeName != null and collegeName != ''">#{collegeName},</if>
            <if test="dean != null and dean != ''">#{dean},</if>
            <if test="contactPhone != null and contactPhone != ''">#{contactPhone},</if>
            '启用',
        </trim>
    </insert>

    <!-- 更新学院 -->
    <update id="update">
        UPDATE college
        <set>
            <if test="collegeName != null and collegeName != ''">college_name = #{collegeName},</if>
            <if test="dean != null and dean != ''">dean = #{dean},</if>
            <if test="contactPhone != null and contactPhone != ''">contact_phone = #{contactPhone},</if>
            <if test="status != null and status != ''">status = #{status},</if>
        </set>
        WHERE id = #{id}
    </update>

    <!-- 批量删除学院 -->
    <delete id="deleteBatch">
        delete from college
        WHERE id IN
        <foreach collection="ids" item="id" open="(" close=")" separator=",">
            #{id}
        </foreach>
    </delete>

    <!-- 查询学院关联的专业数量 -->
    <select id="countRelatedMajors" parameterType="java.lang.Long" resultType="java.lang.Integer">
        SELECT COUNT(*) FROM major WHERE college_id = #{id}
    </select>
    
    <!-- 批量获取学院详情 -->
    <select id="getCollegeDetailsByIds" parameterType="java.util.List" resultType="com.hxq.smart_campus.entity.vo.CollegeDetailVO">
        SELECT * FROM college WHERE id IN
        <foreach collection="ids" item="id" separator="," open="(" close=")">
            #{id}
        </foreach>
    </select>
    
    <!-- 批量查询学院关联的专业数量 -->
    <select id="countRelatedMajorsByCollegeIds" parameterType="java.util.List" resultType="java.lang.Integer">
        SELECT COUNT(*) FROM major WHERE college_id IN
        <foreach collection="collegeIds" item="id" separator="," open="(" close=")">
            #{id}
        </foreach>
    </select>

</mapper>