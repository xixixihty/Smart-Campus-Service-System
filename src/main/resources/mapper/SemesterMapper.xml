<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.hxq.smart_campus.mapper.SemesterMapper">
    <insert id="insertSemester">
        insert into semester
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="name != null and name != ''">name = #{name},</if>
            <if test="startDate != null">start_date = #{startDate},</if>
            <if test="endDate != null">end_date = #{endDate},</if>
            <if test="isCurrent != null">is_current = #{isCurrent},</if>
            <if test="status != null and status != ''">status = #{status},</if>
        </trim>
         values
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="name != null and name != ''">#{name},</if>
            <if test="startDate != null">#{startDate},</if>
            <if test="endDate != null">#{endDate},</if>
            <if test="isCurrent != null">#{isCurrent},</if>
            <if test="status != null and status != ''">#{status},</if>
        </trim>
    </insert>
    <update id="updateSemester">
        update semester
        <set>
            <if test="name != null and name != ''">name = #{name},</if>
            <if test="startDate != null">start_date = #{startDate},</if>
            <if test="endDate != null">end_date = #{endDate},</if>
            <if test="isCurrent != null">is_current = #{isCurrent},</if>
            <if test="status != null and status != ''">status = #{status},</if>
        </set>
        where id = #{id}
    </update>

    <!--批量删除学期-->
    <delete id="deleteBatch">
        delete from semester where id in
        <foreach item="id" collection="ids" separator="," open="(" close=")">
            #{id}
        </foreach>
    </delete>

    <!--获取学期列表-->
    <select id="getSemesterList" resultType="com.hxq.smart_campus.entity.vo.SemesterListVO">
        select id, name, start_date, end_date, is_current, status, create_time
        from semester
        <where>
            <if test="name != null and name != ''">name like CONCAT('%', #{name}, '%')</if>
            <if test="status != null and status != ''">status = #{status}</if>
        </where>
    </select>
    
    <!--设置当前学期-->
    <update id="updateIsCurrentById">
        update semester set is_current = #{isCurrent} where id = #{id}
    </update>
    
    <!--将所有学期设置为非当前学期-->
    <update id="updateAllSemestersToNonCurrent">
        update semester set is_current = 0
    </update>
</mapper>
