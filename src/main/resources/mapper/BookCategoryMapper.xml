<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.hxq.smart_campus.mapper.BookCategoryMapper">

    <!-- 批量删除分类 -->
    <delete id="deleteCategoryBatch">
        delete from book_category where id in #{ids}
        <foreach collection="ids" item="id" open="(" close=")" separator=",">
            #{id}
        </foreach>
    </delete>

    <!-- 获取分类列表 -->
    <select id="getCategoryList" resultType="com.hxq.smart_campus.entity.vo.BookCategoryListVO">
        select id, category_name, category_code, create_time
        from book_category
        <where>
            <if test="categoryName != null and categoryName != ''">category_name like CONCAT('%', #{categoryName}, '%')</if>
        </where>
    </select>
    <!-- 获取分类详情 -->
    <select id="getCategoryDetail" resultType="com.hxq.smart_campus.entity.vo.BookCategoryDetailVO">
        select id, category_name, category_code, create_time, update_time
        from book_category
        where id = #{id}
    </select>
</mapper>