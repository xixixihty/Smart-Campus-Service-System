@Resource
private Cache<Long, Book> bookLocalCache;

public Book getByIdWithFallback(Long id) {
    try {
        // 正常走Redis
        return getById(id);
    } catch (Exception e) {
        log.error("Redis不可用，降级到本地缓存", e);
        // Redis不可用时降级到本地Caffeine缓存
