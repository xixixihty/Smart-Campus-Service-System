二、秒杀 -- 融入选课模块
2.1 场景
选课开始后，大量学生抢同一门热门选修课。

2.2 Lua 脚本（库存扣减 + 一人一单 + 资格预检）
lua
-- select_course.lua
local stock_key = KEYS[1]      -- course:stock:{courseId}
local selected_key = KEYS[2]   -- stu:selected:{studentId}
local student_id = ARGV[1]
local course_id = ARGV[2]

-- 1. 检查是否已选
local is_selected = redis.call('SISMEMBER', selected_key, course_id)
if is_selected == 1 then
    return { -1, 'already_selected' }  -- 已选
end

-- 2. 检查库存
local stock = tonumber(redis.call('GET', stock_key) or "0")
if stock <= 0 then
    return { 0, 'sold_out' }  -- 已满
end

-- 3. 扣库存
redis.call('DECR', stock_key)

-- 4. 标记已选
redis.call('SADD', selected_key, course_id)

-- 5. 异步下单消息写入 Stream
redis.call('XADD', 'stream:course:order', '*', 'studentId', student_id, 'courseId', course_id, 'timestamp', ARGV[3])

return { 1, 'success' }
2.3 Java 调用 Lua 脚本
java
// CourseSelectionController.java
@RestController
@RequestMapping("/course")
public class CourseSelectionController {

    @Resource
    private StringRedisTemplate stringRedisTemplate;
    @Resource
    private RedissonClient redissonClient;

    private static final DefaultRedisScript<List> SELECT_SCRIPT;

    static {
        SELECT_SCRIPT = new DefaultRedisScript<>();
        SELECT_SCRIPT.setLocation(new ClassPathResource("lua/select_course.lua"));
        SELECT_SCRIPT.setResultType(List.class);
    }

    @PostMapping("/select/{courseId}")
    public Result selectCourse(@PathVariable Long courseId) {
        Long studentId = UserHolder.getUser().getId();

        // 选课时间段校验（从Redis获取选课窗口）
        String periodKey = "course:select:period";
        Boolean inPeriod = stringRedisTemplate.opsForValue()
            .getOperations().hasKey(periodKey);
        if (!inPeriod) {
            return Result.fail("不在选课时间段");
        }

        // 执行Lua脚本
        List<String> keys = Arrays.asList(
            "course:stock:" + courseId,
            "stu:selected:" + studentId
        );
        List<Object> result = stringRedisTemplate.execute(
            SELECT_SCRIPT,
            keys,
            studentId.toString(),
            courseId.toString(),
            String.valueOf(System.currentTimeMillis())
        );

        long code = (long) result.get(0);
        if (code == -1) {
            return Result.fail("已选过该课程，请勿重复选择");
        } else if (code == 0) {
            // 进入候补队列
            stringRedisTemplate.opsForZSet().add(
                "course:waiting:" + courseId,
                studentId.toString(),
                System.currentTimeMillis()
            );
            return Result.fail("课程已满，已加入候补队列");
        }

        return Result.success("选课成功");
    }
}
三、分布式锁 -- 融入座位预约模块
3.1 场景
座位预约时需检测时间冲突并写入预约记录。

3.2 Lua 脚本（冲突检测 + 预约写入）
lua
-- reserve_seat.lua
local schedule_key = KEYS[1]    -- seat:schedule:{seatId}:{date}
local start_score = tonumber(ARGV[1])  -- 起始分钟数
local end_score = tonumber(ARGV[2])    -- 结束分钟数
local member = ARGV[3]          -- 预约ID

-- 查找是否有交叉时段
local existing = redis.call('ZRANGEBYSCORE', schedule_key, start_score, end_score, 'LIMIT', 0, 1)
if #existing > 0 then
    return 0  -- 冲突
end

-- 无冲突，插入预约
redis.call('ZADD', schedule_key, start_score, member)

-- 热度统计 +1
redis.call('ZINCRBY', 'seat:popular:week', 1, 'seat:' .. KEYS[2])

return 1
3.3 Java 代码（Redisson 分布式锁 + Lua 脚本）
java
// SeatReservationController.java
@RestController
@RequestMapping("/seat")
public class SeatReservationController {

    @Resource
    private StringRedisTemplate stringRedisTemplate;
    @Resource
    private RedissonClient redissonClient;

    private static final DefaultRedisScript<Long> RESERVE_SCRIPT;

    static {
        RESERVE_SCRIPT = new DefaultRedisScript<>();
        RESERVE_SCRIPT.setLocation(new ClassPathResource("lua/reserve_seat.lua"));
        RESERVE_SCRIPT.setResultType(Long.class);
    }

    @PostMapping("/reserve")
    public Result reserveSeat(@RequestBody SeatReservationDTO dto) {
        Long userId = UserHolder.getUser().getId();

        String lockKey = "seat:lock:" + dto.getSeatId() + ":" + dto.getDate();
        RLock lock = redissonClient.getLock(lockKey);

        try {
            // 等待3秒，最多持有锁10秒
            if (!lock.tryLock(3, 10, TimeUnit.SECONDS)) {
                return Result.fail("当前座位预约繁忙，请稍后重试");
            }

            // 计算时间对应的分钟数
            int startMinute = timeToMinutes(dto.getStartTime()); // eg: "09:30" -> 570
            int endMinute = timeToMinutes(dto.getEndTime());

            // 生成预约ID
            String reservationId = IdUtil.getSnowflakeNextIdStr();

            // 执行Lua脚本
            Long result = stringRedisTemplate.execute(
                RESERVE_SCRIPT,
                Arrays.asList("seat:schedule:" + dto.getSeatId() + ":" + dto.getDate(), dto.getSeatId().toString()),
                String.valueOf(startMinute),
                String.valueOf(endMinute - 1),  // 结束时间不包含最后一分钟
                reservationId
            );

            if (result == 0) {
                return Result.fail("该时间段已被预约，请选择其他时间");
            }

            // 异步写入MySQL
            // ... (通过消息队列或线程池)

            return Result.success("预约成功");

        } catch (InterruptedException e) {
            return Result.fail("系统繁忙");
        } finally {
            if (lock.isHeldByCurrentThread()) {
                lock.unlock();
            }
        }
    }

    private int timeToMinutes(String time) {
        String[] parts = time.split(":");
        return Integer.parseInt(parts[0]) * 60 + Integer.parseInt(parts[1]);
    }
}
四、统计 -- 融入签到、热度排行、UV
4.1 签到（Bitmap）
java
// SignInController.java
@RestController
@RequestMapping("/sign")
public class SignInController {

    @Resource
    private StringRedisTemplate stringRedisTemplate;

    // 签到
    @PostMapping("/do")
    public Result signIn() {
        Long userId = UserHolder.getUser().getId();
        LocalDate now = LocalDate.now();
        String key = "sign:stu:" + userId + ":" + now.getYear() + now.getMonthValue();

        int dayOfMonth = now.getDayOfMonth();
        stringRedisTemplate.opsForValue().setBit(key, dayOfMonth - 1, true);

        // 统计连续签到
        int consecutive = getConsecutiveSignDays(key, dayOfMonth);
        return Result.success("签到成功，连续签到" + consecutive + "天");
    }

    // 统计连续签到天数
    private int getConsecutiveSignDays(String key, int today) {
        List<Long> result = stringRedisTemplate
            .opsForValue()
            .bitField(key,
                BitFieldSubCommands.create()
                    .get(BitFieldSubCommands.BitFieldType.unsigned(today))
                    .valueAt(0)
            );

        long signBit = result == null || result.isEmpty() ? 0 : result.get(0);
        int count = 0;
        for (int i = 0; i < today; i++) {
            if (((signBit >> i) & 1) == 1) {
                count++;
            } else {
                break;
            }
        }
        return count;
    }
}
