一、缓存 -- 融入图书查询模块
1.1 场景
学生端：图书详情查询（高频读取）
管理端：图书信息修改（低频写入）

1.2 落地代码
java
// BookServiceImpl.java
@Service
public class BookServiceImpl implements BookService {

    @Resource
    private BookMapper bookMapper;

    @Resource
    private RBloomFilter<String> bloomFilter;  // 布隆过滤器

    @Resource
    private RedissonClient redissonClient;

    @Resource
    private StringRedisTemplate stringRedisTemplate;

    private static final String CACHE_BOOK_KEY = "cache:book:";
    private static final String LOCK_BOOK_KEY = "lock:book:";
    private static final long CACHE_TTL = 30; // 30分钟 + 随机时间

    @Override
    public Book getById(Long id) {
        String cacheKey = CACHE_BOOK_KEY + id;

        // 1. 布隆过滤器防穿透
        if (!bloomFilter.contains(id.toString())) {
            return null;  // 直接返回不存在
        }

        // 2. 查缓存
        String bookJson = stringRedisTemplate.opsForValue().get(cacheKey);
        if (StrUtil.isNotBlank(bookJson)) {
            return JSONUtil.toBean(bookJson, Book.class);
        }

        // 3. 缓存空值防穿透
        if ("".equals(bookJson)) {
            return null;
        }

        // 4. 互斥锁防击穿
        String lockKey = LOCK_BOOK_KEY + id;
        RLock lock = redissonClient.getLock(lockKey);
        try {
            if (lock.tryLock(3, 10, TimeUnit.SECONDS)) {
                // 双重检查
                bookJson = stringRedisTemplate.opsForValue().get(cacheKey);
                if (StrUtil.isNotBlank(bookJson)) {
                    return JSONUtil.toBean(bookJson, Book.class);
                }

                // 查DB
                Book book = bookMapper.selectById(id);
                if (book == null) {
                    // 缓存空值，防穿透，短TTL
                    stringRedisTemplate.opsForValue().set(cacheKey, "", 2, TimeUnit.MINUTES);
                    return null;
                }

                // 回写缓存，TTL加随机值防雪崩
                int ttl = CACHE_TTL + new Random().nextInt(10);
                stringRedisTemplate.opsForValue().set(cacheKey, JSONUtil.toJsonStr(book), ttl, TimeUnit.MINUTES);
                return book;
            }
        } finally {
            if (lock.isHeldByCurrentThread()) {
                lock.unlock();
            }
        }

        // 未抢到锁，等一会后重试
        try { Thread.sleep(100); } catch (InterruptedException e) { }
        return getById(id);
    }

    // 管理员修改图书后删除缓存
    @Override
    public void updateBook(Book book) {
        bookMapper.updateById(book);
        // 删除而不是更新缓存
        stringRedisTemplate.delete(CACHE_BOOK_KEY + book.getId());
    }
}
