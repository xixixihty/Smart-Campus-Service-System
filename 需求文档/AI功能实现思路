4.4 RAG（检索增强生成）图书知识库
ETL管道流程：

text
MySQL(book表) → DocumentReader(读取) → TextSplitter(分块) → Embedding(向量化) → Elasticsearch(存储)
java
@Configuration
public class RAGConfig {

    @Bean
    public VectorStore vectorStore(ElasticsearchVectorStoreOptions options,
                                    RestClient restClient) {
        return new ElasticsearchVectorStore(options, restClient);
    }

    /**
     * 项目启动时执行ETL：将图书数据加载到向量库
     */
    @Component
    public static class BookETLInitializer implements ApplicationRunner {

        @Resource
        private BookMapper bookMapper;
        @Resource
        private VectorStore vectorStore;

        @Override
        public void run(ApplicationArguments args) {
            List<Book> books = bookMapper.selectAll();

            List<Document> documents = books.stream()
                .map(book -> new Document(
                    String.format("%s %s %s", book.getTitle(), book.getAuthor(), book.getDescription()),
                    Map.of("bookId", book.getId(), "categoryId", book.getCategoryId())
                ))
                .toList();

            vectorStore.add(documents);
        }
    }
}
